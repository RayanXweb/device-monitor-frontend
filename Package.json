    "uuid": "^9.0.1",
    "qs": "^6.11.2",
    "crypto-js": "^4.2.0",
    "react-map-gl": "^7.1.7",
    "react-dropzone": "^14.2.3",
    "react-copy-to-clipboard": "^5.1.0",
    "swr": "^2.2.4",
    "zustand": "^4.4.7",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.2.0",
    "next-themes": "^0.2.1",
    "react-query": "^3.39.3",
    "react-apexcharts": "^1.4.1",
    "apexcharts": "^3.45.0",
    "nprogress": "^0.2.0",
