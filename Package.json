    "react-table": "^7.8.0",
    "react-datepicker": "^4.25.0",
    "react-modal": "^3.16.1",
    "react-player": "^2.13.0",
    "react-audio-player": "^0.17.0",
    "react-webcam": "^7.2.0",
    "chart.js": "^4.4.1",
    "react-chartjs-2": "^5.2.0",
    "leaflet": "^1.9.4",
    "react-leaflet": "^4.2.1",
    "mapbox-gl": "^3.3.0",
    "@mapbox/mapbox-gl-draw": "^1.4.3",
    "socket.io": "^4.5.4",
    "compression": "^1.7.4",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "@vercel/analytics": "^1.1.1",
    "@vercel/speed-insights": "^1.0.1",
    "next-axiom": "^1.2.0",
    "@sentry/nextjs": "^7.93.0"
