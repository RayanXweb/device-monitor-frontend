{
  "name": "device-monitor-frontend",
  "version": "3.0.0",
  "private": true,
  "description": "Professional device monitoring and management platform with real-time surveillance capabilities",
  "author": "Device Monitor Team",
  "license": "MIT",
  "keywords": [
    "device-monitoring",
    "surveillance",
    "remote-control",
    "real-time",
    "nextjs",
    "pwa",
    "react",
    "tailwindcss",
    "socketio",
    "realtime-monitoring"
  ],
  "homepage": "https://device-monitor.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/device-monitor-frontend.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/device-monitor-frontend/issues"
  },
  "scripts": {
    "dev": "next dev",
    "dev:prod": "next dev --turbo",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "build:prod": "NODE_ENV=production next build",
    "start": "next start",
    "start:prod": "NODE_ENV=production next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "export": "next export",
    "clean": "rm -rf .next out node_modules",
    "clean:cache": "rm -rf .next .cache node_modules/.cache",
    "vercel-build": "next build",
    "vercel-dev": "next dev",
    "analyze": "ANALYZE=true next build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky install",
    "pre-commit": "lint-staged",
    "vercel:deploy": "./deploy-full.sh",
    "vercel:preview": "vercel --yes",
    "vercel:prod": "vercel --prod --yes",
    "vercel:env:pull": "vercel env pull .env.local",
    "vercel:env:add": "vercel env add",
    "vercel:logs": "vercel logs",
    "vercel:inspect": "vercel inspect",
    "vercel:alias": "vercel alias",
    "vercel:domains": "vercel domains",
    "vercel:list": "vercel list",
    "vercel:remove": "vercel remove",
    "vercel:link": "vercel link",
    "vercel:env:ls": "vercel env ls",
    "vercel:env:rm": "vercel env rm",
    "postinstall": "next telemetry disable",
    "prebuild": "npm run type-check || true",
    "postbuild": "echo 'Build completed!'"
  },
  "dependencies": {
    "next": "14.0.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "next-pwa": "^5.6.0",
    "next-seo": "^6.4.0",
    "next-auth": "^4.24.5",
