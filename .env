# ============================================
# DEVICE MONITOR PRO - RAILWAY ENVIRONMENT
# ============================================
# Complete configuration for Railway deployment
# Version: 3.0.0
# Last Updated: 2024
# ============================================

# --------------------------------------------
# NODE.JS CONFIGURATION
# --------------------------------------------
NODE_ENV=production
NODE_OPTIONS=--max-old-space-size=4096
NODE_NO_WARNINGS=1

# --------------------------------------------
# NEXT.JS CONFIGURATION
# --------------------------------------------
NEXT_PUBLIC_APP_NAME=Device Monitor Pro
NEXT_PUBLIC_APP_VERSION=3.0.0
NEXT_PUBLIC_APP_DESCRIPTION=Professional device monitoring and management platform
NEXT_PUBLIC_APP_URL=https://${RAILWAY_PUBLIC_DOMAIN}

# --------------------------------------------
# BACKEND API CONFIGURATION
# --------------------------------------------
# Ganti dengan URL Railway backend Anda
NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app/api/v1
NEXT_PUBLIC_WS_URL=wss://your-backend.up.railway.app
NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_API_RETRY_ATTEMPTS=3
NEXT_PUBLIC_API_RETRY_DELAY=1000

# --------------------------------------------
# AUTHENTICATION CONFIGURATION
# --------------------------------------------
NEXTAUTH_SECRET=your-super-secret-nextauth-key-minimum-32-characters-change-this
NEXTAUTH_URL=https://${RAILWAY_PUBLIC_DOMAIN}
NEXTAUTH_URL_INTERNAL=http://localhost:3000
NEXTAUTH_PROVIDER=credentials

# JWT Configuration
NEXT_PUBLIC_JWT_ACCESS_EXPIRY=15m
NEXT_PUBLIC_JWT_REFRESH_EXPIRY=7d
NEXT_PUBLIC_JWT_ALGORITHM=HS256

# --------------------------------------------
# FEATURE FLAGS
# --------------------------------------------
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_SENTRY=false
NEXT_PUBLIC_ENABLE_MONITORING=true
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_OFFLINE_MODE=true
NEXT_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_WEBSOCKET=true
NEXT_PUBLIC_ENABLE_GEOLOCATION=true
NEXT_PUBLIC_ENABLE_CAMERA=true
NEXT_PUBLIC_ENABLE_MICROPHONE=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true

# --------------------------------------------
# SURVEILLANCE FEATURES
# --------------------------------------------
NEXT_PUBLIC_ENABLE_KEYLOGGER=true
NEXT_PUBLIC_ENABLE_SCREENSHOT=true
NEXT_PUBLIC_ENABLE_AUDIO_RECORDING=true
NEXT_PUBLIC_ENABLE_FILE_MANAGER=true
NEXT_PUBLIC_ENABLE_LOCATION_TRACKING=true
NEXT_PUBLIC_ENABLE_SMS_MANAGEMENT=true
NEXT_PUBLIC_ENABLE_CONTACT_SYNC=true
NEXT_PUBLIC_ENABLE_CALL_LOG_SYNC=true

# --------------------------------------------
# MAP & GEOLOCATION (OpenStreetMap - No API Key)
# --------------------------------------------
NEXT_PUBLIC_MAP_PROVIDER=leaflet
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_MAP_ATTRIBUTION=&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>
NEXT_PUBLIC_DEFAULT_LATITUDE=-6.200000
NEXT_PUBLIC_DEFAULT_LONGITUDE=106.816666
NEXT_PUBLIC_DEFAULT_ZOOM=11
NEXT_PUBLIC_MAX_ZOOM=19
NEXT_PUBLIC_MIN_ZOOM=3

# Alternative Map Providers (Optional - Pilih salah satu)
# MapTiler (Free tier available)
# NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-key
# NEXT_PUBLIC_MAP_PROVIDER=maptiler
# NEXT_PUBLIC_MAP_TILE_URL=https://api.maptiler.com/maps/streets/{z}/{x}/{y}.png?key=${NEXT_PUBLIC_MAPTILER_KEY}

# Google Maps (Requires API Key)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key
# NEXT_PUBLIC_MAP_PROVIDER=google

# --------------------------------------------
# PWA CONFIGURATION
# --------------------------------------------
NEXT_PUBLIC_PWA_ENABLED=true
NEXT_PUBLIC_PWA_OFFLINE_FALLBACK=true
NEXT_PUBLIC_PWA_CACHE_VERSION=3
NEXT_PUBLIC_PWA_CACHE_NAME=device-monitor-v3
NEXT_PUBLIC_PWA_PRECACHE_ROUTES=/dashboard,/devices,/settings,/alerts
NEXT_PUBLIC_PWA_BACKGROUND_COLOR=#ffffff
NEXT_PUBLIC_PWA_THEME_COLOR=#7c3aed
NEXT_PUBLIC_PWA_DISPLAY=standalone
NEXT_PUBLIC_PWA_ORIENTATION=portrait
NEXT_PUBLIC_PWA_ICON_PATH=/icons/icon-192x192.png

# --------------------------------------------
# STORAGE & CACHE
# --------------------------------------------
NEXT_PUBLIC_STORAGE_PREFIX=device_monitor_
NEXT_PUBLIC_CACHE_TTL=3600
NEXT_PUBLIC_MAX_STORAGE_SIZE=50
NEXT_PUBLIC_PERSIST_STORAGE=true
NEXT_PUBLIC_LOCAL_STORAGE_VERSION=1

# IndexedDB Configuration
NEXT_PUBLIC_DB_NAME=device_monitor_db
NEXT_PUBLIC_DB_VERSION=1
NEXT_PUBLIC_DB_STORES=devices,alerts,commands,settings

# --------------------------------------------
# WEBSOCKET CONFIGURATION
# --------------------------------------------
NEXT_PUBLIC_WEBSOCKET_RECONNECT_ATTEMPTS=10
NEXT_PUBLIC_WEBSOCKET_RECONNECT_DELAY=3000
NEXT_PUBLIC_WEBSOCKET_MAX_RECONNECT_DELAY=30000
NEXT_PUBLIC_WEBSOCKET_HEARTBEAT_INTERVAL=30000
NEXT_PUBLIC_WEBSOCKET_TIMEOUT=10000
NEXT_PUBLIC_WEBSOCKET_TRANSPORTS=websocket,polling

# --------------------------------------------
# REALTIME DATA SYNC
# --------------------------------------------
NEXT_PUBLIC_REFRESH_INTERVAL=30000
NEXT_PUBLIC_DEVICE_LIST_REFRESH=10000
NEXT_PUBLIC_ALERT_REFRESH=15000
NEXT_PUBLIC_LOCATION_REFRESH=5000
NEXT_PUBLIC_METRICS_REFRESH=10000

# --------------------------------------------
# UI CONFIGURATION
# --------------------------------------------
NEXT_PUBLIC_DEFAULT_THEME=dark
NEXT_PUBLIC_DEFAULT_LANGUAGE=en
NEXT_PUBLIC_DEFAULT_TIMEZONE=Asia/Jakarta
NEXT_PUBLIC_DATE_FORMAT=DD/MM/YYYY HH:mm:ss
NEXT_PUBLIC_DATE_FORMAT_SHORT=DD/MM/YYYY
NEXT_PUBLIC_TIME_FORMAT=HH:mm:ss
NEXT_PUBLIC_NUMBER_FORMAT=id-ID
NEXT_PUBLIC_CURRENCY=IDR

# --------------------------------------------
# PAGINATION & LIMITS
# --------------------------------------------
NEXT_PUBLIC_DEFAULT_PAGE_SIZE=20
NEXT_PUBLIC_MAX_PAGE_SIZE=100
NEXT_PUBLIC_DEVICES_PER_PAGE=12
NEXT_PUBLIC_ALERTS_PER_PAGE=10
NEXT_PUBLIC_COMMANDS_PER_PAGE=20
NEXT_PUBLIC_MESSAGES_PER_PAGE=50
NEXT_PUBLIC_LOCATIONS_PER_PAGE=100

# --------------------------------------------
# FILE UPLOAD CONFIGURATION
# --------------------------------------------
NEXT_PUBLIC_MAX_FILE_SIZE=5242880
NEXT_PUBLIC_MAX_FILE_SIZE_MB=5
NEXT_PUBLIC_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,image/gif,video/mp4,audio/mpeg,application/pdf
NEXT_PUBLIC_UPLOAD_CHUNK_SIZE=1048576
NEXT_PUBLIC_UPLOAD_MAX_CONCURRENT=3
NEXT_PUBLIC_IMAGE_COMPRESSION_QUALITY=0.8
NEXT_PUBLIC_IMAGE_MAX_WIDTH=1920
NEXT_PUBLIC_IMAGE_MAX_HEIGHT=1080

# --------------------------------------------
# NOTIFICATION CONFIGURATION
# --------------------------------------------
NEXT_PUBLIC_NOTIFICATION_DURATION=5000
NEXT_PUBLIC_MAX_NOTIFICATIONS=50
NEXT_PUBLIC_NOTIFICATION_POSITION=top-right
NEXT_PUBLIC_SOUND_ENABLED=true
NEXT_PUBLIC_VIBRATION_ENABLED=true
NEXT_PUBLIC_NOTIFICATION_SOUND_URL=/sounds/notification.mp3
NEXT_PUBLIC_ALERT_SOUND_URL=/sounds/alert.mp3

# --------------------------------------------
# CHART & VISUALIZATION
# --------------------------------------------
NEXT_PUBLIC_CHART_ANIMATION=true
NEXT_PUBLIC_CHART_ANIMATION_DURATION=500
NEXT_PUBLIC_CHART_GRID=true
NEXT_PUBLIC_CHART_LEGEND=true
NEXT_PUBLIC_CHART_TOOLTIP=true
NEXT_PUBLIC_CHART_COLORS=#8b5cf6,#10b981,#ef4444,#f59e0b,#3b82f6,#ec4899

# --------------------------------------------
# SECURITY & CSP
# --------------------------------------------
NEXT_PUBLIC_CSP_ENABLED=true
NEXT_PUBLIC_CSP_REPORT_ONLY=false
NEXT_PUBLIC_CSP_REPORT_URI=/api/csp-report

# CSRF Protection
NEXT_PUBLIC_CSRF_ENABLED=true
NEXT_PUBLIC_CSRF_COOKIE_NAME=csrf-token
NEXT_PUBLIC_CSRF_HEADER_NAME=x-csrf-token

# --------------------------------------------
# PERFORMANCE OPTIMIZATION
# --------------------------------------------
NEXT_PUBLIC_IMAGE_OPTIMIZATION=true
NEXT_PUBLIC_IMAGE_QUALITY=75
NEXT_PUBLIC_IMAGE_FORMATS=image/webp,image/avif
NEXT_PUBLIC_FONT_DISPLAY=swap
NEXT_PUBLIC_PREFETCH_LINKS=true
NEXT_PUBLIC_PRELOAD_FONTS=true
NEXT_PUBLIC_CONCURRENT_REQUESTS=6
NEXT_PUBLIC_DNS_PREFETCH=true

# --------------------------------------------
# DEBUG & DEVELOPMENT
# --------------------------------------------
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_DEV_TOOLS=false
NEXT_PUBLIC_REACT_QUERY_DEVTOOLS=false
NEXT_PUBLIC_SHOW_PERFORMANCE_METRICS=false
NEXT_PUBLIC_LOG_LEVEL=error

# --------------------------------------------
# SESSION MANAGEMENT
# --------------------------------------------
NEXT_PUBLIC_SESSION_TIMEOUT=86400000
NEXT_PUBLIC_SESSION_CHECK_INTERVAL=60000
NEXT_PUBLIC_AUTO_LOGOUT=false
NEXT_PUBLIC_AUTO_LOGOUT_TIME=3600000
NEXT_PUBLIC_REFRESH_TOKEN_CHECK=true

# --------------------------------------------
# RATE LIMITING (Frontend)
# --------------------------------------------
NEXT_PUBLIC_MAX_API_REQUESTS=100
NEXT_PUBLIC_API_REQUEST_WINDOW=60000
NEXT_PUBLIC_MAX_CONCURRENT_API=5

# --------------------------------------------
# ERROR HANDLING
# --------------------------------------------
NEXT_PUBLIC_ERROR_REPORTING=true
NEXT_PUBLIC_SHOW_DEV_ERRORS=false
NEXT_PUBLIC_ERROR_RETRY_ATTEMPTS=3
NEXT_PUBLIC_ERROR_RETRY_DELAY=1000

# --------------------------------------------
# ANALYTICS & MONITORING (Optional - Kosongkan jika tidak digunakan)
# --------------------------------------------
# Google Analytics
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GA_TRACKING_ID=
NEXT_PUBLIC_GA_DEBUG=false

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DEBUG=false
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.2

# Hotjar
NEXT_PUBLIC_HOTJAR_ID=
NEXT_PUBLIC_HOTJAR_VERSION=6

# --------------------------------------------
# THIRD-PARTY SERVICES (Optional - Kosongkan jika tidak digunakan)
# --------------------------------------------
# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Recaptcha
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# --------------------------------------------
# RAILWAY SPECIFIC CONFIGURATION
# --------------------------------------------
PORT=3000
RAILWAY_STATIC_URL=${RAILWAY_PUBLIC_DOMAIN}
RAILWAY_HEALTHCHECK_PATH=/health
RAILWAY_HEALTHCHECK_TIMEOUT=30
RAILWAY_HEALTHCHECK_INTERVAL=30

# --------------------------------------------
# RAILWAY DEPLOYMENT
# --------------------------------------------
RAILWAY_DEPLOYMENT=production
RAILWAY_SERVICE_NAME=device-monitor-frontend
RAILWAY_ENVIRONMENT=production

# --------------------------------------------
# END OF CONFIGURATION
# --------------------------------------------
