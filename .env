# ============================================
# LOCAL DEVELOPMENT FOR RAILWAY
# ============================================

NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Device Monitor Pro (Dev)
NEXT_PUBLIC_APP_VERSION=3.0.0-dev

# Backend URLs (Local)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Features
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_SENTRY=false
NEXT_PUBLIC_ENABLE_MONITORING=true
NEXT_PUBLIC_ENABLE_PWA=false
NEXT_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=false

# Authentication
NEXTAUTH_SECRET=dev-secret-key-do-not-use-in-production
NEXTAUTH_URL=http://localhost:3000

# Map
NEXT_PUBLIC_MAP_PROVIDER=leaflet
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# Debug (Enabled for development)
NEXT_PUBLIC_DEBUG_MODE=true
NEXT_PUBLIC_DEV_TOOLS=true
NEXT_PUBLIC_REACT_QUERY_DEVTOOLS=true
NEXT_PUBLIC_SHOW_PERFORMANCE_METRICS=true

# Mock Data
NEXT_PUBLIC_MOCK_API=true
NEXT_PUBLIC_MOCK_API_DELAY=500
NEXT_PUBLIC_DEVICE_MOCK_DATA=true
